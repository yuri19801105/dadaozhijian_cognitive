# pixi environments
.pixi/*
!.pixi/config.toml

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# === Local project data (WorkBuddy) — not source, per project convention ===
.workbuddy/

# === Runtime artifacts (regenerable) ===
shifang/ledger/*.jsonl
shifang/ledger/.health_cache.json
*.prom

# === stage_b 生成产物（可重生成，非源码）===
stage_b/__pycache__/
stage_b/artifacts/
# 神经蒸馏：训练产物（权重 ~35MB，本地/HF 管理，不进主仓）
stage_b/neural_adapter/
stage_b/neural_train.log

# === Scratch / OS ===
.scratch/
.DS_Store

# === Downloaded binaries / installers accidentally dropped in workspace ===
kubectl
Docker.dmg
*.dmg

# === Editor / temp ===
*.swp
*~

